{
  "name": "data-dashboard",
  "version": "0.2.3",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "electron:dev": "node electron/dev.js",
    "electron:build": "next build && electron-builder"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "16.2.7",
    "@supabase/supabase-js": "^2.105.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dexie": "^4.4.4",
    "electron": "^42.5.1",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "lucide-react": "^1.12.0",
    "next": "16.2.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "uuid": "^14.0.0"
  },
  "build": {
    "appId": "com.meo.dataentry",
    "productName": "MEO Data Entry",
    "publish": [
      {
        "provider": "github",
        "owner": "meo-mcbryle",
        "repo": "meo-data-entry"
      }
    ],
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
